{
  "name": "@kongxiangyiren/ld-api",
  "type": "module",
  "version": "0.0.2",
  "description": "本地扩散模型（Local Diffusion）HTTP API 的 Node.js / TypeScript 客户端，支持文生图、图生图、inpaint 以及扩散过程预览。",
  "author": "空巷一人",
  "license": "MIT",
  "homepage": "https://github.com/kongxiangyiren/ld-api#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kongxiangyiren/ld-api.git"
  },
  "bugs": {
    "url": "https://github.com/kongxiangyiren/ld-api/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "bumpp": "^11.1.0",
    "sharp": "^0.35.3",
    "tsdown": "^0.22.7",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "axios": "^1.18.1"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "packageManager": "npm@11.16.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.com"
  },
  "keywords": [
    "ld-api",
    "Local Dream"
  ]
}
